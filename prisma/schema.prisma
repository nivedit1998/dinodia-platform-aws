generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  INSTALLER
  TENANT
}

enum HomeStatus {
  ACTIVE
  TRANSFER_PENDING
  UNCLAIMED
}

enum MatterCommissioningStatus {
  CREATED
  IN_PROGRESS
  NEEDS_INPUT
  SUCCEEDED
  FAILED
  CANCELED
}

enum CommissioningKind {
  MATTER
  DISCOVERY
}

enum AuditEventType {
  SELL_INITIATED
  CLAIM_CODE_GENERATED
  HOME_CLAIM_ATTEMPTED
  HOME_RESET
  OWNER_TRANSFERRED
  TENANT_DELETED
  HOME_CLAIMED
  AUTOMATION_CREATED
  AUTOMATION_UPDATED
  AUTOMATION_DELETED
  HOMEOWNER_POLICY_ACCEPTED
  HOMEOWNER_POLICY_EMAIL_RESEND_REQUESTED
  SUPPORT_REQUEST_CREATED
  SUPPORT_REQUEST_APPROVED
  SUPPORT_REQUEST_REVOKED
  SUPPORT_CREDENTIALS_VIEWED
  SUPPORT_IMPERSONATION_STARTED
  SUPPORT_IMPERSONATION_STOPPED
  ROOM_ACCESS_REQUESTED
  ROOM_ACCESS_APPROVED
  ROOM_ACCESS_REJECTED
  PROPERTY_MANAGER_UPDATED
  ROOM_QR_REKEYED
  ROOM_HA_AREA_RESYNCED
}

enum HomeownerPolicyNotificationRecipientType {
  HOMEOWNER
  INSTALLER
}

enum HomeownerPolicyNotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
}

enum HomeContactType {
  PROPERTY_MANAGER
}

enum RoomStatus {
  ACTIVE
  REKEYED
  REVOKED
}

enum RoomAccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  CANCELED
}

enum RoomAccessApprovalKind {
  APPROVE
  REJECT
}

enum HomeownerOnboardingFlowType {
  SETUP_QR
  CLAIM_CODE
}

enum AuthChallengePurpose {
  ADMIN_EMAIL_VERIFY
  TENANT_ENABLE_2FA
  LOGIN_NEW_DEVICE
  REMOTE_ACCESS_SETUP
  PASSWORD_RESET
  SUPPORT_HOME_ACCESS
  SUPPORT_USER_REMOTE_SUPPORT
}

enum DeviceStatus {
  ACTIVE
  STOLEN
  BLOCKED
}

enum StepUpPurpose {
  REMOTE_ACCESS_SETUP
}

enum SupportRequestKind {
  HOME_ACCESS
  USER_REMOTE_ACCESS
}

enum SupportAccessScope {
  VIEW_HOME_STATUS
  VIEW_CREDENTIALS
  IMPERSONATE_USER
}

enum HomeAutomationSource {
  DINODIA_UI
}

model Home {
  id                                    Int                                   @id @default(autoincrement())
  status                                HomeStatus                            @default(ACTIVE)
  addressLine1                          String
  addressLine2                          String?
  city                                  String
  state                                 String?
  postcode                              String
  country                               String
  haConnection                          HaConnection                          @relation(fields: [haConnectionId], references: [id])
  haConnectionId                        Int                                   @unique
  claimCodeHash                         String?                               @unique
  claimCodeIssuedAt                     DateTime?
  claimCodeConsumedAt                   DateTime?
  auditEvents                           AuditEvent[]
  homeownerPolicyAcceptances            HomeownerPolicyAcceptance[]
  homeownerPolicyNotificationDeliveries HomeownerPolicyNotificationDelivery[]
  pendingHomeownerOnboardings           PendingHomeownerOnboarding[]
  homeContacts                          HomeContact[]
  users                                 User[]
  automationOwnerships                  AutomationOwnership[]
  homeAutomations                       HomeAutomation[]
  hubInstall                            HubInstall?                           @relation("HomeHubInstall")
  createdAt                             DateTime                              @default(now())
  updatedAt                             DateTime                              @updatedAt
}

model AuditEvent {
  id          String         @id @default(uuid())
  type        AuditEventType
  metadata    Json?
  home        Home           @relation(fields: [homeId], references: [id])
  homeId      Int
  actorUser   User?          @relation("AuditEventActor", fields: [actorUserId], references: [id])
  actorUserId Int?
  createdAt   DateTime       @default(now())

  @@index([homeId])
  @@index([actorUserId])
}

model AuditEventArchive {
  id          String         @id @default(uuid())
  type        AuditEventType
  metadata    Json?
  homeId      Int?
  actorUserId Int?
  createdAt   DateTime
  archivedAt  DateTime       @default(now())
}

model User {
  id                             Int                             @id @default(autoincrement())
  username                       String                          @unique
  passwordHash                   String
  mustChangePassword             Boolean                         @default(false)
  passwordChangedAt              DateTime?
  email                          String?
  emailPending                   String?
  emailVerifiedAt                DateTime?
  phoneNumber                    String?
  homeownerPolicyAcceptedVersion String?
  homeownerPolicyAcceptedAt      DateTime?
  email2faEnabled                Boolean                         @default(false)
  role                           Role                            @default(TENANT)
  home                           Home?                           @relation(fields: [homeId], references: [id])
  homeId                         Int?
  haConnection                   HaConnection?                   @relation("AssignedHaConnection", fields: [haConnectionId], references: [id])
  haConnectionId                 Int?
  ownedHaConnection              HaConnection?                   @relation("OwnedHaConnection")
  accessRules                    AccessRule[]
  alexaAuthCodes                 AlexaAuthCode[]
  alexaRefreshTokens             AlexaRefreshToken[]
  alexaEventToken                AlexaEventToken?
  alexaSkillUserLinks            AlexaSkillUserLink[]
  newDeviceCommissioningSessions NewDeviceCommissioningSession[]
  automationOwnerships           AutomationOwnership[]
  homeAutomationsCreated         HomeAutomation[]                @relation("HomeAutomationCreatedBy")
  trustedDevices                 TrustedDevice[]
  authChallenges                 AuthChallenge[]
  loginIntents                   LoginIntent[]
  stepUpApprovals                StepUpApproval[]
  remoteAccessLeases             RemoteAccessLease[]
  homeownerPolicyAcceptances     HomeownerPolicyAcceptance[]
  pendingHomeownerOnboardings    PendingHomeownerOnboarding[]
  actedAuditEvents               AuditEvent[]                    @relation("AuditEventActor")
  approvedSupportRequests        SupportRequest[]                @relation("SupportRequestApprovedBy")
  revokedSupportRequests         SupportRequest[]                @relation("SupportRequestRevokedBy")
  createdAt                      DateTime                        @default(now())
  updatedAt                      DateTime                        @updatedAt
  roomAccessRequests             RoomAccessRequest[]

  @@index([homeId])
}

model LoginIntent {
  id          String    @id @default(cuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      Int
  username    String
  role        Role
  deviceId    String
  deviceLabel String?
  expiresAt   DateTime
  consumedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model TrustedDevice {
  id             String    @id @default(uuid())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         Int
  deviceId       String
  label          String?
  firstSeenAt    DateTime  @default(now())
  lastSeenAt     DateTime  @default(now())
  revokedAt      DateTime?
  sessionVersion Int       @default(0)

  @@unique([userId, deviceId])
  @@index([userId])
  @@index([deviceId])
}

model DeviceRegistry {
  deviceId    String       @id
  status      DeviceStatus @default(ACTIVE)
  label       String?
  firstSeenAt DateTime     @default(now())
  lastSeenAt  DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model AuthChallenge {
  id         String               @id @default(uuid())
  user       User                 @relation(fields: [userId], references: [id])
  userId     Int
  purpose    AuthChallengePurpose
  email      String
  deviceId   String?
  tokenHash  String               @unique
  expiresAt  DateTime
  approvedAt DateTime?
  consumedAt DateTime?
  createdAt  DateTime             @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@index([approvedAt])
}

model StepUpApproval {
  id         String        @id @default(uuid())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     Int
  deviceId   String
  purpose    StepUpPurpose
  approvedAt DateTime      @default(now())
  usedAt     DateTime?
  createdAt  DateTime      @default(now())

  @@index([userId, deviceId, purpose])
  @@index([deviceId])
}

model RemoteAccessLease {
  id        String        @id @default(uuid())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  deviceId  String
  purpose   StepUpPurpose
  tokenHash String        @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime      @default(now())

  @@index([userId, deviceId, purpose])
  @@index([expiresAt])
  @@index([deviceId])
}

model HaConnection {
  id                       Int     @id @default(autoincrement())
  baseUrl                  String // e.g. https://xxxx.ui.nabu.casa or http://homeassistant.local:8123
  cloudUrl                 String? // optional HA Cloud URL shared across admin + tenants
  haUsername               String?
  haUsernameCiphertext     String?
  haPassword               String?
  haPasswordCiphertext     String?
  longLivedToken           String?
  longLivedTokenCiphertext String?
  longLivedTokenHash       String? @unique
  devicesVersion           Int     @default(0)

  owner   User? @relation("OwnedHaConnection", fields: [ownerId], references: [id])
  ownerId Int?  @unique

  home                           Home?
  users                          User[]                          @relation("AssignedHaConnection")
  devices                        Device[]
  monitoringReadings             MonitoringReading[]
  boilerTemperatureReadings      BoilerTemperatureReading[]
  boilerUsageAccumulators        BoilerUsageAccumulator[]
  radiatorUsageAccumulators      RadiatorUsageAccumulator[]
  newDeviceCommissioningSessions NewDeviceCommissioningSession[]
  createdAt                      DateTime                        @default(now())
  updatedAt                      DateTime                        @updatedAt
}

model HubInstall {
  id                           String                       @id @default(uuid())
  serial                       String                       @unique
  bootstrapSecretCiphertext    String
  syncSecretCiphertext         String?
  platformSyncEnabled          Boolean                      @default(true)
  platformSyncIntervalMinutes  Int                          @default(2)
  rotateEveryMinutes           Int                          @default(60) // minutes
  graceMinutes                 Int                          @default(20) // minutes
  publishedHubTokenVersion     Int                          @default(0)
  lastAckedHubTokenVersion     Int                          @default(0)
  heatingUsageResetRequestedAt DateTime?
  heatingUsageResetCompletedAt DateTime?
  lastReportedLanBaseUrl       String?
  lastReportedLanBaseUrlAt     DateTime?
  lastReportedHaAreas          Json?
  lastReportedHaAreasAt        DateTime?
  lastSeenAt                   DateTime?
  home                         Home?                        @relation("HomeHubInstall", fields: [homeId], references: [id], onDelete: SetNull)
  homeId                       Int?                         @unique
  pendingHomeownerOnboardings  PendingHomeownerOnboarding[]
  hubTokens                    HubToken[]
  rooms                        Room[]
  roomAccessRequests           RoomAccessRequest[]
  createdAt                    DateTime                     @default(now())
  updatedAt                    DateTime                     @updatedAt
}

model HomeownerPolicyAcceptance {
  id                      String                                @id @default(uuid())
  home                    Home                                  @relation(fields: [homeId], references: [id], onDelete: Cascade)
  homeId                  Int
  homeownerUser           User                                  @relation(fields: [homeownerUserId], references: [id], onDelete: Cascade)
  homeownerUserId         Int
  policyVersion           String
  acceptedAt              DateTime                              @default(now())
  signatureName           String
  acceptedStatements      Json
  addressReference        String
  approvedSupportContacts Json?
  notificationPreference  String?
  ipHash                  String?
  deviceFingerprintHash   String?
  notifications           HomeownerPolicyNotificationDelivery[]
  createdAt               DateTime                              @default(now())
  updatedAt               DateTime                              @updatedAt

  @@unique([homeownerUserId, policyVersion])
  @@index([homeId])
}

model HomeownerPolicyNotificationDelivery {
  id             String                                    @id @default(uuid())
  acceptance     HomeownerPolicyAcceptance                 @relation(fields: [acceptanceId], references: [id], onDelete: Cascade)
  acceptanceId   String
  home           Home                                      @relation(fields: [homeId], references: [id], onDelete: Cascade)
  homeId         Int
  recipientType  HomeownerPolicyNotificationRecipientType
  recipientEmail String
  status         HomeownerPolicyNotificationDeliveryStatus @default(PENDING)
  attemptCount   Int                                       @default(0)
  lastAttemptAt  DateTime?
  sentAt         DateTime?
  lastError      String?
  createdAt      DateTime                                  @default(now())
  updatedAt      DateTime                                  @updatedAt

  @@unique([acceptanceId, recipientType])
  @@index([homeId, status])
}

model PendingHomeownerOnboarding {
  id                    String                      @id @default(cuid())
  flowType              HomeownerOnboardingFlowType
  policyVersionRequired String                      @default("2026-V1")
  claimCodeHash         String?
  hubInstall            HubInstall?                 @relation(fields: [hubInstallId], references: [id], onDelete: SetNull)
  hubInstallId          String?
  home                  Home?                       @relation(fields: [homeId], references: [id], onDelete: SetNull)
  homeId                Int?
  user                  User?                       @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId                Int?
  proposedUsername      String
  proposedPasswordHash  String
  proposedEmail         String
  deviceId              String
  deviceLabel           String?
  emailVerifiedAt       DateTime?
  policyAcceptedAt      DateTime?
  expiresAt             DateTime
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt

  @@index([flowType])
  @@index([expiresAt])
  @@index([homeId])
  @@index([userId])
  @@index([hubInstallId])
  @@index([claimCodeHash])
}

enum HubTokenStatus {
  PENDING
  ACTIVE
  GRACE
  REVOKED
}

model HubToken {
  id              String         @id @default(uuid())
  hubInstall      HubInstall     @relation(fields: [hubInstallId], references: [id], onDelete: Cascade)
  hubInstallId    String
  version         Int
  status          HubTokenStatus
  tokenHash       String
  tokenCiphertext String
  publishedAt     DateTime?
  graceUntil      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([hubInstallId, version])
  @@unique([hubInstallId, tokenHash])
  @@index([hubInstallId, status])
  @@index([tokenHash])
}

model HubAgentNonce {
  id        Int      @id @default(autoincrement())
  serial    String
  nonce     String
  ts        BigInt
  createdAt DateTime @default(now())

  @@unique([serial, nonce])
  @@index([createdAt])
}

model AccessRule {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  // Tenants are now associated to an AREA only
  area      String
  createdAt DateTime @default(now())
}

model HomeContact {
  id         String          @id @default(uuid())
  home       Home            @relation(fields: [homeId], references: [id], onDelete: Cascade)
  homeId     Int
  type       HomeContactType
  email      String
  verifiedAt DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([homeId, type])
  @@index([homeId])
}

model Room {
  id                 String              @id @default(uuid())
  hubInstall         HubInstall          @relation(fields: [hubInstallId], references: [id], onDelete: Cascade)
  hubInstallId       String
  displayName        String
  haAreaName         String
  haAreaNameOriginal String
  qrKeyVersion       Int                 @default(1)
  qrSecretHash       String
  qrSecretCiphertext String
  status             RoomStatus          @default(ACTIVE)
  accessRequests     RoomAccessRequest[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([hubInstallId, haAreaName])
  @@index([hubInstallId])
}

model RoomAccessRequest {
  id             String                    @id @default(uuid())
  hubInstall     HubInstall                @relation(fields: [hubInstallId], references: [id], onDelete: Cascade)
  hubInstallId   String
  room           Room                      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId         String
  homeIdSnapshot Int?
  requestedName  String
  requestedEmail String
  requestedPhoneNumber String?
  tenantUser     User?                     @relation(fields: [tenantUserId], references: [id], onDelete: SetNull)
  tenantUserId   Int?
  status         RoomAccessRequestStatus   @default(PENDING)
  resolvedAt     DateTime?
  approvalTokens RoomAccessApprovalToken[]
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  @@index([hubInstallId])
  @@index([roomId])
  @@index([status])
}

model RoomAccessApprovalToken {
  id             String                 @id @default(uuid())
  request        RoomAccessRequest      @relation(fields: [requestId], references: [id], onDelete: Cascade)
  requestId      String
  kind           RoomAccessApprovalKind
  recipientEmail String
  tokenHash      String                 @unique
  expiresAt      DateTime
  consumedAt     DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([requestId])
  @@index([expiresAt])
}

model Device {
  id             Int          @id @default(autoincrement())
  haConnection   HaConnection @relation(fields: [haConnectionId], references: [id])
  haConnectionId Int

  entityId             String
  name                 String
  area                 String?
  label                String?
  blindTravelSeconds   Int?
  boilerPowerKw        Float?
  heatingPricePerKwh   Float?
  boilerEfficiencyBand String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([haConnectionId, entityId])
}

model MonitoringReading {
  id             Int          @id @default(autoincrement())
  haConnection   HaConnection @relation(fields: [haConnectionId], references: [id])
  haConnectionId Int
  entityId       String
  state          String
  numericValue   Float?
  unit           String?
  hubOnline      Boolean?
  hubOfflineGraceSeconds Int?
  hubStatusSource String?
  capturedAt     DateTime     @default(now())

  @@index([haConnectionId, entityId, capturedAt])
  @@index([haConnectionId, capturedAt], map: "MonitoringReading_haConnectionId_capturedAt_valid_idx")
}

model BoilerTemperatureReading {
  id                       Int          @id @default(autoincrement())
  haConnection             HaConnection @relation(fields: [haConnectionId], references: [id])
  haConnectionId           Int
  entityId                 String
  numericValue             Float
  currentTemperature       Float
  targetTemperature        Float?
  onForSeconds             Int?
  offForSeconds            Int?
  unknownForSeconds        Int?
  averageEfficiencyPercent Float?
  kwhOnEstimated           Float?
  unit                     String       @default("°C")
  capturedAt               DateTime     @default(now())

  @@index([haConnectionId, entityId, capturedAt])
  @@index([haConnectionId, capturedAt])
}

model BoilerUsageAccumulator {
  id                                      Int          @id @default(autoincrement())
  haConnection                            HaConnection @relation(fields: [haConnectionId], references: [id])
  haConnectionId                          Int
  entityId                                String
  onSeconds                               Int          @default(0)
  offSeconds                              Int          @default(0)
  unknownSeconds                          Int          @default(0)
  efficiencyWeightedOnSeconds             Float        @default(0)
  efficiencyOnSeconds                     Int          @default(0)
  lastSeenAt                              DateTime?
  lastWasOn                               Boolean?
  lastWasKnown                            Boolean?
  lastSnapshotOnSeconds                   Int?
  lastSnapshotOffSeconds                  Int?
  lastSnapshotUnknownSeconds              Int?
  lastSnapshotEfficiencyWeightedOnSeconds Float?
  lastSnapshotEfficiencyOnSeconds         Int?
  lastSnapshotAt                          DateTime?
  createdAt                               DateTime     @default(now())
  updatedAt                               DateTime     @updatedAt

  @@unique([haConnectionId, entityId])
  @@index([haConnectionId])
}

model RadiatorUsageAccumulator {
  id                         Int          @id @default(autoincrement())
  haConnection               HaConnection @relation(fields: [haConnectionId], references: [id])
  haConnectionId             Int
  entityId                   String
  onSeconds                  Int          @default(0)
  offSeconds                 Int          @default(0)
  unknownSeconds             Int          @default(0)
  lastSeenAt                 DateTime?
  lastWasOn                  Boolean?
  lastWasKnown               Boolean?
  lastSnapshotOnSeconds      Int?
  lastSnapshotOffSeconds     Int?
  lastSnapshotUnknownSeconds Int?
  lastSnapshotAt             DateTime?
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt

  @@unique([haConnectionId, entityId])
  @@index([haConnectionId])
}

model AlexaAuthCode {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  user        User     @relation(fields: [userId], references: [id])
  userId      Int
  clientId    String
  redirectUri String
  expiresAt   DateTime
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model AlexaRefreshToken {
  id         Int       @id @default(autoincrement())
  tokenHash  String    @unique
  user       User      @relation(fields: [userId], references: [id])
  userId     Int
  clientId   String
  revoked    Boolean   @default(false)
  revokedAt  DateTime?
  lastUsedAt DateTime  @default(now())
  createdAt  DateTime  @default(now())
}

model AlexaSkillUserLink {
  id                 Int       @id @default(autoincrement())
  alexaUserId        String    @unique
  user               User      @relation(fields: [userId], references: [id])
  userId             Int
  skillId            String?
  marketplace        String?
  locale             String?
  linkedAt           DateTime  @default(now())
  disabledAt         DateTime?
  disabledReason     String?
  lastEventAt        DateTime?
  lastEventRequestId String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([userId])
}

model AlexaEventToken {
  id           Int      @id @default(autoincrement())
  user         User     @relation(fields: [userId], references: [id])
  userId       Int      @unique
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model NewDeviceCommissioningSession {
  id                    String                    @id @default(uuid())
  user                  User                      @relation(fields: [userId], references: [id])
  userId                Int
  haConnection          HaConnection              @relation(fields: [haConnectionId], references: [id])
  haConnectionId        Int
  requestedArea         String
  requestedName         String?
  requestedDinodiaType  String?
  requestedHaLabelId    String?
  setupPayloadHash      String?
  manualPairingCodeHash String?
  haFlowId              String?
  status                MatterCommissioningStatus @default(CREATED)
  kind                  CommissioningKind         @default(MATTER)
  error                 String?
  lastHaStep            Json?
  beforeDeviceIds       Json?
  beforeEntityIds       Json?
  afterDeviceIds        Json?
  afterEntityIds        Json?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  @@index([userId])
  @@index([haConnectionId])
  @@index([haFlowId])
  @@index([kind])
}

model AutomationOwnership {
  id           Int      @id @default(autoincrement())
  home         Home     @relation(fields: [homeId], references: [id])
  homeId       Int
  user         User     @relation(fields: [userId], references: [id])
  userId       Int
  automationId String
  createdAt    DateTime @default(now())

  @@unique([automationId, homeId])
  @@index([homeId])
  @@index([userId])
  @@index([automationId])
}

model HomeAutomation {
  home            Home                 @relation(fields: [homeId], references: [id], onDelete: Cascade)
  homeId          Int
  automationId    String
  createdByUser   User?                @relation("HomeAutomationCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdByUserId Int?
  source          HomeAutomationSource @default(DINODIA_UI)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@id([homeId, automationId])
  @@index([homeId])
  @@index([createdByUserId])
}

model SupportRequest {
  id               String              @id @default(uuid())
  kind             SupportRequestKind
  homeId           Int
  targetUserId     Int?
  installerUserId  Int
  authChallengeId  String              @unique
  reason           String?
  scope            SupportAccessScope?
  approvedByUserId Int?
  approvedBy       User?               @relation("SupportRequestApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  revokedAt        DateTime?
  revokedByUserId  Int?
  revokedBy        User?               @relation("SupportRequestRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)
  consumedAt       DateTime?
  createdAt        DateTime            @default(now())

  @@index([homeId])
  @@index([targetUserId])
  @@index([installerUserId])
  @@index([approvedByUserId])
  @@index([revokedByUserId])
}
